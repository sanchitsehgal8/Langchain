   "source": [
    "chat = ChatHuggingFace(llm=llm)\n",
    "lm_with_tools = chat.bind_tools([get_conversion_factor, convert])\n",
    "messages=[]\n",
    "query = HumanMessage('what is the conversion factor from USD to INR and what is the value of 100 USD in INR')\n",
    "messages.append(query)\n",
    "result = lm_with_tools.invoke(messages)\n",
    "messages.append(result)\n",
    "conversion_factor = get_conversion_factor.invoke(result.tool_calls[0])\n",
    "messages.append(conversion_factor)\n",
    "conversion_rate = json.loads(conversion_factor.content)[\"conversion_rate\"]\n",
    "converted_value = convert.invoke({\"base_currency_value\": 100, \"conversion_rate\": conversion_rate})\n",
    "messages.append(converted_value)\n",
    "lm_with_tools.invoke(messages).content\n",
    "## this is not automoted tool calling, we are manually invoking the tools based on the llm output, in future we can automate this process by parsing the llm output and invoking the tools accordingly.\n",
    "##hence this is not entirely a ai agent "
   ]
