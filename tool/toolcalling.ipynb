   "source": [
    "# tool create\n",
    "\n",
    "@tool\n",
    "def multiply(a: int, b: int) -> int:\n",
    "  \"\"\"Given 2 numbers a and b this tool returns their product\"\"\"\n",
    "  return a * b\n",
    "\n",
    "\n",
    "print(multiply.invoke({\"a\":3, \"b\":5}))\n",
    "print(multiply.name)\n",
    "print(multiply.description)\n",
    "print(multiply.args)\n",
    "print(multiply.args_schema.model_json_schema())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "905fc2b2",
   "metadata": {},
   "outputs": [],
   "source": [
    "#tool binding\n",
    "chat = ChatHuggingFace(llm=llm)\n",
    "llm_with_tools = chat.bind_tools([multiply])\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "55b993cf",
   "metadata": {},
   "outputs": [],
   "source": [
    "query = HumanMessage('can you multiply 3 with 1000')\n",
    "messages = [query]\n",
    "result = llm_with_tools.invoke(messages)\n",
    "messages.append(result)"
   ]
  },
